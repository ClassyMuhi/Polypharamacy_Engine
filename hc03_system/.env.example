# HC-03 System Environment Configuration
# Copy this to .env and update with your settings

# OpenAI API Configuration
OPENAI_API_KEY=your-openai-api-key-here

# Application Settings
DEBUG_MODE=True
LOG_LEVEL=INFO

# FastAPI Settings
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000
FASTAPI_RELOAD=True

# MongoDB Settings
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=polypharmacy_db

# Optional: Custom LLM Model
# LLM_MODEL=gpt-4
